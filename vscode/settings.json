{
  "$schema": "vscode://schemas/settings/user",
  "editor.tabSize": 2,
  "editor.rulers": [
    {
      "column": 128,
    }
  ],
  "editor.fontSize": 13,
  "workbench.iconTheme": "material-icon-theme",
  "editor.minimap.enabled": false,
  "explorer.confirmDelete": false,
  "extensions.ignoreRecommendations": true,
  "explorer.confirmDragAndDrop": false,
  "window.autoDetectColorScheme": true,
  "workbench.startupEditor": "none",
  "explorer.compactFolders": false,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "diffEditor.renderSideBySide": false,
  "git.openRepositoryInParentFolders": "always",
  "js.updateImportsOnFileMove.enabled": "always",
  "ts.updateImportsOnFileMove.enabled": "always",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "files.exclude": {
    "**/node_modules": true
  },
  "files.associations": {
    "*.plist": "xml"
  },
  "go.toolsManagement.autoUpdate": true,
  "editor.fontFamily": "'JetBrains Mono', Monaco, 'Courier New', monospace",
  "github.copilot.nextEditSuggestions.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  "[typescriptreact]": {
    "editor.tabSize": 2
  },
  "[typescript]": {
    "editor.tabSize": 2
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "chat.viewWelcome.enabled": false,
  "chat.viewSessions.enabled": false,
  "explorer.confirmPasteNative": false,
}